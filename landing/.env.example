# AGENTICUM G5 — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Backend API ──────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Production values (Cloud Run):
# VITE_API_URL=https://genius-backend-697051612685.europe-west1.run.app
# VITE_WS_URL=wss://genius-backend-697051612685.europe-west1.run.app

# ── Firebase / GCP ───────────────────────────────────────
# Get from: https://console.firebase.google.com → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_GCP_PROJECT_ID=your-gcp-project-id

# ── Optional ─────────────────────────────────────────────
# YouTube video ID for the demo player on the landing page
VITE_DEMO_VIDEO_ID=

# Google Maps (for client geo features)
VITE_GOOGLE_MAPS_API_KEY=your-maps-api-key
